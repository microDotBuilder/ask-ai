{
  "extends": "@askai/config/tsconfig/extension",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true
  },
  "include": [
    ".wxt/wxt.d.ts",
    "entrypoints/**/*.ts",
    "entrypoints/**/*.tsx",
    "store/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "wxt.config.ts"
  ]
}

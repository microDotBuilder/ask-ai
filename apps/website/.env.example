# Copy to `.env` for local dev, or set these in Cloudflare Pages → Settings → Environment variables.

# Public canonical URL of the deployed site (used for canonical/OG tags + sitemap).
PUBLIC_SITE_URL=https://askpane.ca

# Chrome Web Store listing URL. Leave EMPTY until the listing is approved — the
# "Add to Chrome" button renders as "coming soon" while this is blank. Once the
# extension is published, set it to e.g.
# https://chromewebstore.google.com/detail/<your-extension-id>
PUBLIC_CHROME_STORE_URL=

# Optional: a GitHub token lifts the 60 req/hr anonymous API limit when the build
# resolves release download links. A read-only/public token is enough. Either
# GITHUB_TOKEN or GH_TOKEN (what the `gh` CLI uses) is accepted.
# GITHUB_TOKEN=

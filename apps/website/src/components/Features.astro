---
// Feature copy is drawn from the extension README so the site stays truthful to
// what actually ships. Icons are inline lucide-style paths (no JS, no runtime).
const features = [
  {
    n: "01",
    title: "Reads the page for you",
    body: "Extracts the readable text of the current tab and uses it as context — no copy-pasting articles, docs, or GitHub pages.",
    path: "M4 5h16M4 10h16M4 15h10M4 20h7",
  },
  {
    n: "02",
    title: "Side-panel, per tab",
    body: "Opens in Chrome's side panel with its own session per tab, so switching pages never mixes conversations.",
    path: "M4 4h16v16H4zM14 4v16",
  },
  {
    n: "03",
    title: "Quick actions",
    body: "One click to summarize, explain, rewrite, translate, simplify, or explain code — on the full page, a selection, or pasted text.",
    path: "M13 2 3 14h7l-1 8 10-12h-7z",
  },
  {
    n: "04",
    title: "Bring your own key",
    body: "Use your own OpenAI or OpenRouter key. OpenRouter also unlocks Claude, Gemini, and more model families through one key.",
    path: "M7 11V7a5 5 0 0 1 10 0v4M5 11h14v9H5z",
  },
  {
    n: "05",
    title: "Local-first & private",
    body: "Keys and chat history are stored locally. Page content is only sent when you ask. Exclude sites or disable history anytime.",
    path: "M12 3 4 6v6c0 5 3.5 7.5 8 9 4.5-1.5 8-4 8-9V6z",
  },
  {
    n: "06",
    title: "Your models, your way",
    body: "Choose default providers and models, favorite the ones you use, hide the rest. Streamed responses you can stop mid-answer.",
    path: "M12 3v3m0 12v3M5.6 5.6l2.1 2.1m8.6 8.6 2.1 2.1M3 12h3m12 0h3M5.6 18.4l2.1-2.1m8.6-8.6 2.1-2.1",
  },
];
---

<section id="features" class="py-24">
  <div class="mx-auto max-w-content px-6">
    <div class="font-mono text-[11.5px] uppercase tracking-[0.1em] text-accent">Features</div>
    <h2 class="mt-3.5 max-w-[20ch] font-display text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.02em]">
      A reading &amp; research copilot, built into the browser
    </h2>
    <p class="mt-4 max-w-[58ch] text-[1.05rem] text-ink-muted">
      Made for long-form web content — articles, documentation, technical references, and business pages.
    </p>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <article class="group relative overflow-hidden rounded-2xl border border-line bg-gradient-to-b from-panel to-[#080a0d] p-[26px] transition-[transform,border-color] duration-200 hover:-translate-y-[3px] hover:border-[rgba(124,135,255,0.4)]">
            <span class="absolute right-[22px] top-[20px] font-mono text-[11px] text-ink-faint">{f.n}</span>
            <div class="mb-[18px] grid h-[42px] w-[42px] place-items-center rounded-[11px] border border-line bg-bg text-accent-bright">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={f.path} />
              </svg>
            </div>
            <h3 class="mb-[9px] font-display text-[1.12rem] font-semibold">{f.title}</h3>
            <p class="text-[0.94rem] leading-[1.55] text-ink-muted">{f.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

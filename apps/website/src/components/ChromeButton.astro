---
import { SITE, chromeStoreLive } from "../lib/site";

interface Props {
  /** "lg" for the hero, "md" for the download cards. */
  size?: "md" | "lg";
}

const { size = "lg" } = Astro.props;
const pad = size === "lg" ? "px-6 py-3.5 text-base" : "px-5 py-3 text-sm";
---

{
  chromeStoreLive ? (
    <a
      href={SITE.chromeStoreUrl}
      target="_blank"
      rel="noopener"
      class={`inline-flex items-center justify-center gap-2.5 rounded-xl bg-brand font-semibold text-white shadow-glow transition-transform hover:-translate-y-0.5 ${pad}`}
    >
      <svg width="20" height="20" viewBox="0 0 48 48" aria-hidden="true">
        <circle cx="24" cy="24" r="9" fill="#fff" />
        <path fill="#fff" d="M24 4a20 20 0 0 1 17.3 10H24a10 10 0 0 0-9.2 6.1L7 9.5A20 20 0 0 1 24 4Z" opacity=".9" />
        <path fill="#fff" d="M44 24a20 20 0 0 1-24.6 19.5L29 27a10 10 0 0 0 .9-11H44Z" opacity=".75" />
        <path fill="#fff" d="M4 24a20 20 0 0 0 15.4 19.5L24 34a10 10 0 0 1-9.6-7.3L5 11A19.9 19.9 0 0 0 4 24Z" opacity=".6" />
      </svg>
      Add to Chrome
    </a>
  ) : (
    <span
      class={`inline-flex items-center justify-center gap-2.5 rounded-xl border border-brand/40 bg-brand/10 font-semibold text-ink shadow-glow ${pad}`}
    >
      <span class="relative flex h-2.5 w-2.5">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand opacity-60" />
        <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-brand" />
      </span>
      Chrome Web Store — coming soon
    </span>
  )
}

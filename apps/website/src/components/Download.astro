---
import ChromeButton from "./ChromeButton.astro";
import { SITE } from "../lib/site";
import { formatSize, type ResolvedRelease } from "../lib/releases";

interface Props {
  stable: ResolvedRelease;
  alpha: ResolvedRelease;
}

const { stable, alpha } = Astro.props;

const zipChannels = [
  {
    rel: stable,
    label: "Stable",
    tone: "ok" as const,
    blurb: "The recommended manual build. Tested and stable.",
  },
  {
    rel: alpha,
    label: "Alpha",
    tone: "warn" as const,
    blurb: "Bleeding-edge preview. New features first — expect rough edges.",
  },
];
---

<section id="download" class="mx-auto max-w-content px-5 py-20 sm:px-8">
  <div class="max-w-2xl">
    <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">Three ways to install</h2>
    <p class="mt-4 text-ink-muted">
      One-click from the Chrome Web Store, or download a build and load it unpacked while the listing is in review.
    </p>
  </div>

  <div class="mt-12 grid gap-4 lg:grid-cols-3">
    <!-- Primary: Chrome Web Store -->
    <article class="flex flex-col rounded-2xl border border-brand/40 bg-gradient-to-b from-brand/10 to-panel/60 p-6">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold">Chrome Web Store</h3>
        <span class="rounded-full bg-brand/20 px-2.5 py-1 text-[11px] font-medium text-[#a7c4ff]">Recommended</span>
      </div>
      <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-muted">
        One-click install with automatic updates. No developer mode required.
      </p>
      <div class="mt-6">
        <ChromeButton size="md" />
      </div>
    </article>

    <!-- Manual ZIP builds -->
    {
      zipChannels.map(({ rel, label, tone, blurb }) => {
        const size = formatSize(rel.sizeBytes);
        const href = rel.downloadUrl ?? rel.pageUrl;
        return (
          <article class="flex flex-col rounded-2xl border border-line bg-panel/60 p-6">
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-semibold">{label} build</h3>
              <span
                class:list={[
                  "rounded-full px-2.5 py-1 text-[11px] font-medium",
                  tone === "ok" ? "bg-ok/25 text-[#6fdfb0]" : "bg-warn/20 text-warn",
                ]}
              >
                {tone === "ok" ? "Stable" : "Preview"}
              </span>
            </div>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-muted">{blurb}</p>
            <p class="mt-4 font-mono text-xs text-ink-faint">
              {rel.version ?? "Not published yet"}
              {size ? ` · ${size}` : ""}
            </p>
            <a
              href={href}
              class="mt-3 inline-flex items-center justify-center gap-2 rounded-xl border border-line bg-panel px-5 py-3 text-sm font-medium text-ink transition-colors hover:border-brand/40 hover:bg-panel-hover"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14" />
              </svg>
              {rel.available ? "Download ZIP" : "View releases"}
            </a>
          </article>
        );
      })
    }
  </div>

  <!-- Load-unpacked instructions for the ZIP builds -->
  <div class="mt-10 rounded-2xl border border-line bg-panel/40 p-6 sm:p-8">
    <h3 class="text-base font-semibold">Loading a downloaded build</h3>
    <p class="mt-1 text-sm text-ink-muted">Only needed for the ZIP builds above — the Web Store version installs itself.</p>
    <ol class="mt-5 grid gap-4 sm:grid-cols-3">
      {
        [
          { n: "1", t: "Unzip the download", d: "Extract the ZIP anywhere on your machine." },
          { n: "2", t: "Open chrome://extensions", d: "Paste it into the address bar, then toggle on Developer mode." },
          { n: "3", t: "Load unpacked", d: "Click “Load unpacked” and pick the unzipped folder." },
        ].map((s) => (
          <li class="rounded-xl border border-line-soft bg-bg p-4">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-brand/20 font-mono text-sm text-[#a7c4ff]">{s.n}</span>
            <p class="mt-3 text-sm font-medium">{s.t}</p>
            <p class="mt-1 text-sm text-ink-muted">{s.d}</p>
          </li>
        ))
      }
    </ol>
    <p class="mt-5 text-xs text-ink-faint">
      The same ZIP works on macOS, Windows, and Linux. Requires Chrome 116+. See all builds on
      <a href={SITE.releasesUrl} target="_blank" rel="noopener" class="text-ink underline-offset-2 hover:underline">GitHub Releases</a>.
    </p>
  </div>
</section>

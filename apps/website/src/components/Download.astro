---
import { SITE, chromeStoreLive } from "../lib/site";
import { formatSize, type ResolvedRelease } from "../lib/releases";

interface Props {
  stable: ResolvedRelease;
  alpha: ResolvedRelease;
}

const { stable, alpha } = Astro.props;

const zipChannels = [
  {
    rel: stable,
    label: "Stable build",
    tag: "Stable",
    tagClass: "bg-[rgba(86,216,166,0.16)] text-ok",
    blurb: "The recommended manual build. Tested and stable.",
  },
  {
    rel: alpha,
    label: "Alpha build",
    tag: "Preview",
    tagClass: "bg-[rgba(231,177,90,0.16)] text-warn",
    blurb: "Bleeding-edge preview. New features first — expect rough edges.",
  },
];
---

<section id="download" class="py-24">
  <div class="mx-auto max-w-content px-6">
    <div class="font-mono text-[11.5px] uppercase tracking-[0.1em] text-accent">Download</div>
    <h2 class="mt-3.5 max-w-[20ch] font-display text-[clamp(1.9rem,3.4vw,2.7rem)] font-semibold leading-[1.05] tracking-[-0.02em]">
      Three ways to install
    </h2>
    <p class="mt-4 max-w-[58ch] text-[1.05rem] text-ink-muted">
      One-click from the Chrome Web Store, or download a build and load it unpacked while the listing is in review.
    </p>

    <div class="mt-12 grid gap-4 lg:grid-cols-3">
      <!-- Chrome Web Store card -->
      <article class="flex flex-col rounded-2xl border border-[rgba(124,135,255,0.4)] bg-gradient-to-b from-[rgba(124,135,255,0.1)] to-panel p-[26px]">
        <div class="mb-3 flex items-center justify-between gap-2.5">
          <h3 class="font-display text-[1.15rem] font-semibold">Chrome Web Store</h3>
          <span class="rounded-full bg-[rgba(124,135,255,0.16)] px-2.5 py-1 font-mono text-[10.5px] text-accent-bright">Recommended</span>
        </div>
        <p class="flex-1 text-[0.94rem] text-ink-muted">
          One-click install with automatic updates. No developer mode required.
        </p>
        {
          chromeStoreLive ? (
            <a
              href={SITE.chromeStoreUrl}
              target="_blank"
              rel="noopener"
              class="mt-[18px] inline-flex items-center justify-center gap-2 self-start rounded-[13px] bg-white px-4 py-[11px] text-[14px] font-semibold text-[#0a0b0e] transition-transform hover:-translate-y-px"
            >
              Add to Chrome
            </a>
          ) : (
            <span class="mt-[18px] inline-flex items-center gap-2.5 self-start rounded-[13px] border border-[rgba(124,135,255,0.32)] bg-[rgba(124,135,255,0.08)] px-4 py-[11px] text-[14px] font-semibold text-ink">
              <span class="ping-dot" aria-hidden="true" />
              Coming soon
            </span>
          )
        }
      </article>

      <!-- Stable + Alpha ZIP cards -->
      {
        zipChannels.map(({ rel, label, tag, tagClass, blurb }) => {
          const size = formatSize(rel.sizeBytes);
          const href = rel.downloadUrl ?? rel.pageUrl;
          return (
            <article class="flex flex-col rounded-2xl border border-line bg-panel p-[26px]">
              <div class="mb-3 flex items-center justify-between gap-2.5">
                <h3 class="font-display text-[1.15rem] font-semibold">{label}</h3>
                <span class={`rounded-full px-2.5 py-1 font-mono text-[10.5px] ${tagClass}`}>{tag}</span>
              </div>
              <p class="flex-1 text-[0.94rem] text-ink-muted">{blurb}</p>
              <div class="mt-4 font-mono text-[11.5px] text-ink-faint">
                {rel.version ?? "Not published yet"}
                {size ? ` · ${size}` : ""}
              </div>
              <a
                href={href}
                class="mt-3.5 inline-flex w-full items-center justify-center gap-2 rounded-[11px] border border-line bg-panel px-[18px] py-[11px] text-[14.5px] font-semibold text-ink transition-colors hover:border-line-strong hover:bg-panel-strong"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14" />
                </svg>
                {rel.available ? "Download ZIP" : "View releases"}
              </a>
            </article>
          );
        })
      }
    </div>

    <p class="mt-[26px] text-center text-[0.9rem] text-ink-faint">
      The same ZIP works on macOS, Windows, and Linux. Requires Chrome 116+. See all builds on
      <a href={SITE.releasesUrl} target="_blank" rel="noopener" class="text-ink underline underline-offset-2">GitHub Releases</a>.
    </p>
  </div>
</section>

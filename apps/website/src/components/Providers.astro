---
const providers = [
  { name: "OpenAI", models: "GPT", src: "/providers/openai.svg" },
  { name: "Anthropic", models: "Claude", src: "/providers/anthropic.svg" },
  { name: "Google", models: "Gemini", src: "/providers/gemenai.svg" },
];
---

<section id="providers" class="border-y border-line bg-gradient-to-b from-[#080a0d] to-bg">
  <div class="mx-auto max-w-content px-6 py-16 text-center">
    <div class="mb-[18px] font-mono text-[11.5px] uppercase tracking-[0.1em] text-accent">Providers</div>
    <p class="mx-auto max-w-[60ch] text-[1.06rem] text-ink-muted">
      Plug in your own key for <b class="font-semibold text-ink">OpenAI</b>,
      <b class="font-semibold text-ink">Anthropic</b>, or
      <b class="font-semibold text-ink">Google</b> — or route all of them through a single
      <b class="font-semibold text-ink">OpenRouter</b> key.
    </p>
    <div class="mt-9 flex flex-wrap justify-center gap-[14px]">
      {
        providers.map((p) => (
          <span class="flex items-center gap-2.5 rounded-xl border border-line bg-panel px-[22px] py-[14px] text-ink">
            <img src={p.src} alt="" class="h-6 w-6 object-contain" />
            <span class="font-display text-[15px] font-semibold">{p.name}</span>
            <span class="font-mono text-[11px] text-ink-faint">{p.models}</span>
          </span>
        ))
      }
    </div>
  </div>
</section>

---
import { SITE } from "../lib/site";
---

<header class="sticky top-0 z-30 border-b border-line/70 bg-bg/80 backdrop-blur">
  <nav class="mx-auto flex max-w-content items-center justify-between gap-4 px-5 py-3.5 sm:px-8">
    <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight">
      <img src="/brand-logo.png" width="28" height="28" alt="" class="rounded-md" />
      <span>{SITE.name}</span>
    </a>

    <div class="hidden items-center gap-7 text-sm text-ink-muted md:flex">
      <a href="#features" class="transition-colors hover:text-ink">Features</a>
      <a href="#providers" class="transition-colors hover:text-ink">Providers</a>
      <a href="#download" class="transition-colors hover:text-ink">Download</a>
      <a href="/privacy" class="transition-colors hover:text-ink">Privacy</a>
    </div>

    <div class="flex items-center gap-3">
      <a
        href={SITE.repoUrl}
        target="_blank"
        rel="noopener"
        class="hidden text-sm text-ink-muted transition-colors hover:text-ink sm:inline"
        >GitHub</a
      >
      <a
        href="#download"
        class="rounded-lg bg-brand px-3.5 py-2 text-sm font-medium text-white shadow-glow transition-transform hover:-translate-y-px"
        >Get Ask AI</a
      >
    </div>
  </nav>
</header>
